# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Dependencies
node_modules/

# Build output
dist/
**/dist/
tmp/
out-tsc/
*.tsbuildinfo

# Angular
.angular/
web/.angular/

# IDE
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Logs & coverage
/.sass-cache
/connect.lock
/coverage
npm-debug.log
yarn-error.log
*.log

# OS
.DS_Store
Thumbs.db

# Local database & secrets
data/*.sqlite
data/*.sqlite-journal
data/platform.json
data/secrets.enc
api/data/*.sqlite
api/data/*.sqlite-journal

# Test run artifacts (keep directory placeholder)
artifacts/*
!artifacts/.gitkeep

# Playwright / Cucumber outputs
tests/test-results/
tests/playwright-report/
tests/report.json
**/playwright-output/

# Environment & secrets (never commit)
.env
.env.*
!.env.example
api/.env
**/.env.local
