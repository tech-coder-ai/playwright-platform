generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  runArtifactsConfig String   @default("{\"screenshot\":\"on-failure\",\"video\":\"on-failure\"}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  environments     Environment[]
  testSuites       TestSuite[]
  stepDefinitions  StepDefinition[]
  pageObjects      PageObject[]
  secrets          Secret[]
  schedules        Schedule[]
  testRuns         TestRun[]
}

model Environment {
  id        String   @id @default(cuid())
  projectId String
  name      String
  baseUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secrets  Secret[]
  testRuns TestRun[]
  schedules Schedule[]

  @@unique([projectId, name])
}

model TestSuite {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCase[]
  testRuns  TestRun[]
}

model TestCase {
  id        String   @id @default(cuid())
  suiteId   String
  name      String
  type      String   // gherkin | playwright-native
  filePath  String
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suite      TestSuite   @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  testResults TestResult[]
}

model StepDefinition {
  id             String   @id @default(cuid())
  projectId      String
  pattern        String
  helperFunction String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PageObject {
  id            String   @id @default(cuid())
  projectId     String
  name          String
  screenName    String
  version       Int      @default(1)
  classFilePath String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Secret {
  id            String   @id @default(cuid())
  projectId     String
  environmentId String?
  name          String
  encryptedValue String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  @@unique([projectId, name, environmentId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   // admin | editor | viewer
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Schedule {
  id                 String   @id @default(cuid())
  projectId          String
  name               String
  cronExpression     String
  suiteIds           String   @default("[]")
  environmentId      String?
  enabled            Boolean  @default(true)
  notificationConfig String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  testRuns    TestRun[]
}

model TestRun {
  id            String    @id @default(cuid())
  projectId     String
  suiteId       String?
  scheduleId    String?
  environmentId String?
  status        String    @default("pending") // pending | running | passed | failed | cancelled
  triggeredBy   String    @default("manual")  // manual | schedule
  headed        Boolean   @default(false)
  logPath       String?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suite       TestSuite?   @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  schedule    Schedule?    @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  environment Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  testResults TestResult[]
}

model TestResult {
  id            String   @id @default(cuid())
  runId         String
  testCaseId    String
  status        String   // passed | failed | skipped
  durationMs    Int?
  errorMessage  String?
  artifactPaths String   @default("[]")
  stepsJson     String   @default("[]")
  createdAt     DateTime @default(now())

  run      TestRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
}
