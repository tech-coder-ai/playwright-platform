DATABASE_URL="file:../data/db.sqlite"
# Database provider: prisma (default, SQLite + Prisma) | json (file store) | oracle
DB_PROVIDER=prisma
JSON_DB_PATH=../data/platform.json
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECTION_STRING=localhost:1521/XEPDB1

# Extra CSS selectors treated as "app is loading" by test helpers (comma-separated).
# Helpers hold all actions while any of these (or the built-in spinner/skeleton
# selectors) are visible. Set this if your app uses a custom loading indicator.
# PW_LOADING_INDICATORS=.my-app-spinner,.busy-overlay

# Browser for test runs and codegen: playwright (default) | npm (use chromium npm package)
BROWSER_PROVIDER=playwright

# Where the recording browser runs: local (default) | remote
#   local  — `playwright codegen` opens a headed window on the machine running
#            the API. Fine for laptops; useless once the API is deployed.
#   remote — headless Chromium on the server, streamed into the web UI (CDP
#            screencast); clicks/keystrokes are forwarded back and recorded
#            server-side. Use this for any server deployment.
CODEGEN_RECORDER=local
# Set true to forbid the UI from overriding CODEGEN_RECORDER per session.
CODEGEN_RECORDER_LOCKED=false
# JPEG quality of the streamed viewport (1-100, default 60).
CODEGEN_STREAM_QUALITY=60
# Extra Chromium args for the remote recording browser (space-separated),
# e.g. --no-sandbox on hardened Linux hosts.
CODEGEN_BROWSER_ARGS=

# Allowed browser origins for API + websockets (comma-separated).
CORS_ORIGINS=http://localhost:4200
# Absolute path to a Chromium-based browser. Overrides all auto-detection.
# On locked-down machines this can point at installed Chrome or Edge, e.g.
# C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
CHROMIUM_EXECUTABLE_PATH=

SECRETS_ENCRYPTION_KEY="change-me-in-production-32chars!!"
ARTIFACTS_DIR="../artifacts"
TESTS_DIR="../tests"
# LLM provider for test generation: stellar (default, local endpoint, no key) | openai
LLM_PROVIDER=stellar
# Stellar chat endpoint (request body: { systemPrompt, userMessage })
STELLAR_API_URL=http://localhost:8080/apiv1/stellar/chat
# Only required when LLM_PROVIDER=openai
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
# Auth (optional — set AUTH_ENABLED=true to require login)
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production-jwt-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Notifications (email requires SMTP when using schedule failure alerts)
APP_BASE_URL=http://localhost:4200
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
