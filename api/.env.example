DATABASE_URL="file:../data/db.sqlite"
# Database provider: prisma (default, SQLite + Prisma) | json (file store) | oracle
DB_PROVIDER=prisma
JSON_DB_PATH=../data/platform.json
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECTION_STRING=localhost:1521/XEPDB1

# Browser for test runs and codegen: playwright (default) | npm (use chromium npm package)
BROWSER_PROVIDER=playwright
# Absolute path to a Chromium-based browser. Overrides all auto-detection.
# On locked-down machines this can point at installed Chrome or Edge, e.g.
# C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
CHROMIUM_EXECUTABLE_PATH=

SECRETS_ENCRYPTION_KEY="change-me-in-production-32chars!!"
ARTIFACTS_DIR="../artifacts"
TESTS_DIR="../tests"
# LLM provider for test generation: stellar (default, local endpoint, no key) | openai
LLM_PROVIDER=stellar
# Stellar chat endpoint (request body: { systemPrompt, userMessage })
STELLAR_API_URL=http://localhost:8080/apiv1/stellar/chat
# Only required when LLM_PROVIDER=openai
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
# Auth (optional — set AUTH_ENABLED=true to require login)
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production-jwt-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Notifications (email requires SMTP when using schedule failure alerts)
APP_BASE_URL=http://localhost:4200
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
